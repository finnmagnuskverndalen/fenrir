# Fenrir - Network Security Scanner
# Copy this file to .env and fill in your values

# OpenRouter API key (required for AI analysis)
# Get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use
# Free options: meta-llama/llama-3.3-70b-instruct, google/gemini-2.0-flash-exp, deepseek/deepseek-chat
# Recommended paid: anthropic/claude-sonnet-4-5, mistralai/mistral-large
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# NVD API key (optional but recommended — increases rate limits)
# Get one free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Server settings
HOST=127.0.0.1
PORT=8765
DEBUG=false

# Dry-run mode — set to false to allow actual exploitation (use with extreme caution)
DRY_RUN=true

# Allow scanning public IPs — keep false unless you know what you are doing
ALLOW_PUBLIC_IPS=false

# Max tokens for AI responses
AI_MAX_TOKENS=4096
